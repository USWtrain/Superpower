  </div>
</div>

<footer class="idx-footer">
  <p>US Wellness · Superpower Health Events · For internal use only · Not for distribution</p>
  <img src="https://uswtrain.github.io/GenRapid/US_Wellness_Logo.png" alt="US Wellness" onerror="this.style.display='none'">
</footer>

</body>
</html>
